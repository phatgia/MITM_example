<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Secure Chat Demo"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="32dp"/>

    <Button
        android:id="@+id/btnLogin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="1. Đăng nhập (Lấy Token)" />

    <EditText
        android:id="@+id/etMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Nội dung nhạy cảm (VD: Chuyển 100$)"
        android:layout_marginTop="24dp"
        android:minLines="2" />

    <Button
        android:id="@+id/btnSend"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="2. Gửi Tin Nhắn"
        android:layout_marginTop="8dp" />

    <Switch
        android:id="@+id/switchPinning"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Bật SSL Certificate Pinning"
        android:layout_marginTop="24dp" />

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Trạng thái: Chưa thực hiện"
        android:layout_marginTop="24dp"
        android:textColor="#FF0000" />

</LinearLayout>
